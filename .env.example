# Copy to .env for local secrets and overrides (gitignored).
#
# Shared ports and names live in config.env (committed).

# Google Places API — https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=

# Override Tailscale hostname if MagicDNS name differs from "homelab"
# TAILNET_HOST=homelab
# NEXT_PUBLIC_API_URL=http://homelab:8000

# Override database credentials locally if needed
# POSTGRES_PASSWORD=change-me
