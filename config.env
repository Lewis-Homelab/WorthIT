# =============================================================================
# Project configuration — safe to commit (no secrets).
# =============================================================================
#
# Edit this file on your laptop and push to git. The server picks it up on
# deploy — no manual server configuration required.
#
# Optional secrets or local overrides: copy .env.example → .env (gitignored).
#
# New project: ./scripts/init-project.sh <app-name> [host-port]
# =============================================================================

# Application identity (Docker container name, pyproject name)
APP_NAME=hello-homelab

# HOST_PORT = published on laptop/server; APP_PORT = inside the container
HOST_PORT=5050
APP_PORT=5001

# Health check path — must match a route in your app
HEALTH_PATH=/health

# Git branch deployed by CI/CD
DEPLOY_BRANCH=main

# Server clone path — set the same value as GitHub repo variable DEPLOY_PATH
DEPLOY_PATH=/opt/apps/hello-homelab

# --- Optional: registry-based deploy (uncomment image line in compose.prod.yaml) ---
# IMAGE=ghcr.io/youruser/hello-homelab
# GIT_SHA=latest
