# =============================================================================
# WorthIT — project configuration (safe to commit, no secrets)
# =============================================================================

APP_NAME=worthit

# API (FastAPI)
HOST_PORT=8000
APP_PORT=8000
HEALTH_PATH=/health

# Frontend (Next.js)
WEB_HOST_PORT=3050

# Tailscale MagicDNS hostname for this server (Mac + homelab on same tailnet).
TAILNET_HOST=homelab
# URL the browser uses to call the API — must be reachable from your Mac, not localhost.
NEXT_PUBLIC_API_URL=http://homelab:8000

# PostgreSQL
POSTGRES_USER=worthit
POSTGRES_PASSWORD=worthit
POSTGRES_DB=worthit
POSTGRES_HOST_PORT=5432

# Git branch deployed by CI/CD
DEPLOY_BRANCH=main
DEPLOY_PATH=/home/lewis/homelab/repos/WorthIT

